{
  "dashboard": {
    "title": "Capacity & Rate Limiting",
    "tags": ["capacity", "limits", "layer-c"],
    "timezone": "UTC",
    "schemaVersion": 36,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Rate Limit Hits",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(rate_limit_hits_total[1m])",
            "legendFormat": "{{tenant_id}} {{resource}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Token Usage by Tenant",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(token_usage_total[1m])",
            "legendFormat": "{{tenant_id}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Token Budget Utilization %",
        "type": "gauge",
        "targets": [
          {
            "expr": "(token_usage_daily / token_budget_daily) * 100",
            "legendFormat": "{{tenant_id}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 90}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Concurrency Utilization",
        "type": "graph",
        "targets": [
          {
            "expr": "concurrent_executions / concurrency_limit",
            "legendFormat": "{{tenant_id}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      }
    ],
    "templating": {
      "list": [
        {
          "name": "tenant",
          "type": "query",
          "query": "label_values(token_usage_total, tenant_id)"
        }
      ]
    }
  }
}
